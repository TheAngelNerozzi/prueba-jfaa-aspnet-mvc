@{
    ViewData["Title"] = "Cuenta Bloqueada";
    Layout = "_Layout";
}

<div class="blocked-container">
    <div class="blocked-card">
        <div class="text-center mb-4">
            <div class="blocked-avatar mb-3">
                <i class="bi bi-person-x-fill" style="font-size: 3rem;"></i>
            </div>
            <h4 class="fw-bold text-danger-dark mb-3">Cuenta bloqueada temporalmente</h4>
            <p class="text-muted">
                Su cuenta ha sido bloqueada temporalmente debido a exceso de intentos fallidos de inicio de sesión.
                Haga clic en el botón para restablecer e intentar nuevamente.
            </p>
        </div>
        <form asp-controller="Account" asp-action="DesbloquearCuenta" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary w-100 btn-ingresar">
                Restablecer cuenta e intentar de nuevo
            </button>
        </form>
    </div>
</div>