@{
    ViewData["Title"] = "Cuenta Bloqueada";
    Layout = "_Layout";
}

<div class="blocked-container">
    <div class="blocked-card">
        <div class="text-center mb-4">
            <div class="blocked-icon mb-3">
                <i class="bi bi-person-lock" style="font-size: 2.8rem; color: #2196F3;"></i>
            </div>
            <h5 class="fw-bold mb-3" style="color: #333;">Cuenta bloqueada temporalmente</h5>
            <p class="text-muted" style="font-size: 0.88rem; line-height: 1.6;">
                Has excedido el número máximo de intentos fallidos. 
                Por seguridad, tu cuenta ha sido bloqueada temporalmente.
            </p>
        </div>
        <form asp-controller="Account" asp-action="DesbloquearCuenta" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary w-100 btn-ingresar">
                Restablecer cuenta e intentar de nuevo
            </button>
        </form>
    </div>
</div>