@model PruebaASPNet.Models.Usuario
@{
    ViewData["Title"] = "Perfil de usuario";
    Layout = "_Layout";
}

<div class="perfil-wrapper">
    <!-- Sidebar -->
    <div class="perfil-sidebar">
        <div class="sidebar-icons d-flex flex-column align-items-center gap-4 pt-4">
            <a href="#" class="sidebar-icon active" title="Inicio">
                <i class="bi bi-house-door"></i>
            </a>
            <a href="#" class="sidebar-icon" title="Lista">
                <i class="bi bi-list-ul"></i>
            </a>
            <a href="#" class="sidebar-icon" title="Documentos">
                <i class="bi bi-file-earmark-text"></i>
            </a>
            <a href="#" class="sidebar-icon" title="Buscar">
                <i class="bi bi-search"></i>
            </a>
        </div>
    </div>

    <!-- Main content -->
    <div class="perfil-main">
        <!-- User card -->
        <div class="user-card mb-4">
            <div class="d-flex align-items-center gap-3">
                <div class="user-avatar">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-1">@Model.NombreCompleto</h5>
                    <span class="badge bg-success">Activo</span>
                    <span class="text-muted ms-2 small">@Model.Rol</span>
                    <br />
                    <span class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@(Model.Ubicacion ?? "No especificada")</span>
                </div>
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs perfil-tabs mb-4" id="perfilTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="basica-tab" data-bs-toggle="tab" data-bs-target="#basica" type="button" role="tab">
                    Información básica
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="responsabilidades-tab" data-bs-toggle="tab" data-bs-target="#responsabilidades" type="button" role="tab">
                    Responsabilidades
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="historial-tab" data-bs-toggle="tab" data-bs-target="#historial" type="button" role="tab">
                    Historial de responsabilidades
                </button>
            </li>
        </ul>

        <!-- Tab content -->
        <div class="tab-content" id="perfilTabContent">
            <!-- Información básica -->
            <div class="tab-pane fade show active" id="basica" role="tabpanel">
                <div class="info-table-card">
                    <table class="table table-borderless info-table">
                        <tbody>
                            <tr>
                                <td class="label-cell">Nombres</td>
                                <td class="value-cell">@Model.Nombres</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Primer Apellido</td>
                                <td class="value-cell">@Model.PrimerApellido</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Segundo Apellido</td>
                                <td class="value-cell">@Model.SegundoApellido</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Tipo Documento</td>
                                <td class="value-cell">@Model.TipoDocumento</td>
                            </tr>
                            <tr>
                                <td class="label-cell">N° Documento</td>
                                <td class="value-cell">@Model.NumeroDocumento</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Fecha nacimiento</td>
                                <td class="value-cell">@(Model.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "-")</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Nacionalidad</td>
                                <td class="value-cell">@Model.Nacionalidad</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Sexo</td>
                                <td class="value-cell">@Model.Sexo</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Correo principal</td>
                                <td class="value-cell">@Model.CorreoPrincipal</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Correo secundario</td>
                                <td class="value-cell">@(Model.CorreoSecundario ?? "-")</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Teléfono Móvil</td>
                                <td class="value-cell">@(Model.TelefonoMovil ?? "-")</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Tipo Comunicación</td>
                                <td class="value-cell">@(Model.TipoComunicacion ?? "-")</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Fecha contratación</td>
                                <td class="value-cell">@(Model.FechaContratacion?.ToString("dd/MM/yyyy") ?? "-")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Responsabilidades -->
            <div class="tab-pane fade" id="responsabilidades" role="tabpanel">
                <div class="info-table-card">
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-clipboard-data" style="font-size: 3rem;"></i>
                        <p class="mt-3">No hay responsabilidades asignadas actualmente.</p>
                    </div>
                </div>
            </div>

            <!-- Historial -->
            <div class="tab-pane fade" id="historial" role="tabpanel">
                <div class="info-table-card">
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-clock-history" style="font-size: 3rem;"></i>
                        <p class="mt-3">No hay historial de responsabilidades.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>