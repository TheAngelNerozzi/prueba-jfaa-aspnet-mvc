@{
    ViewData["Title"] = "Bienvenida";
    Layout = "_Layout";
}
@{
    string nombre = ViewBag.Nombre as string ?? "Usuario";
}

<div class="welcome-container">
    <div class="welcome-card">
        <div class="text-center">
            <!-- Llama/alpaca icon in pink circle -->
            <div class="welcome-icon-circle mb-4">
                <span style="font-size: 3rem;">🦙</span>
            </div>
            <h4 class="fw-bold text-dark mb-2">¡Bienvenida, @nombre!</h4>
            <p class="text-muted mb-1">Su cuenta en el aplicativo X está activada.</p>
            <p class="text-muted mb-4">Ya puede iniciar sesión.</p>
            <form asp-controller="Home" asp-action="IniciarSesion" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary btn-ingresar px-5">
                    Iniciar sesión
                </button>
            </form>
        </div>
    </div>
</div>