<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEPIAK</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1lJO5qGp5ObXWqZ6E8M3/nhMz7Gf7" crossorigin="anonymous">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Red Header -->
    <header class="app-header">
        <div class="header-content d-flex align-items-center justify-content-between">
            <!-- Left: hamburger (only on perfil) -->
            @if (ViewContext.RouteData.Values["action"]?.ToString() == "Perfil")
            {
                <button class="btn header-btn" aria-label="Menú">
                    <i class="bi bi-list" style="font-size: 1.5rem; color: white;"></i>
                </button>
            }
            else
            {
                <div></div>
            }

            <!-- Center: title (only on perfil) -->
            @if (ViewContext.RouteData.Values["action"]?.ToString() == "Perfil")
            {
                <span class="header-title">Perfil de usuario</span>
            }
            else if (ViewContext.RouteData.Values["action"]?.ToString() == "CuentaBloqueada")
            {
                <span class="header-title">CEPIAK</span>
            }
            else
            {
                <div></div>
            }

            <!-- Right: help icon + user info (only on perfil) -->
            @if (ViewContext.RouteData.Values["action"]?.ToString() == "Perfil")
            {
                <div class="d-flex align-items-center gap-3">
                    <button class="btn header-btn" aria-label="Ayuda">
                        <i class="bi bi-question-circle" style="font-size: 1.4rem; color: white;"></i>
                    </button>
                    <div class="d-flex align-items-center gap-2">
                        <div class="header-user-circle">
                            <i class="bi bi-person-fill" style="color: white; font-size: 1rem;"></i>
                        </div>
                        <div class="d-none d-md-block">
                            <div class="header-user-name">@(Context.Session.GetString("NombreCompleto") ?? "Usuario")</div>
                            <div class="header-user-role">@(Context.Session.GetString("Rol") ?? "")</div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <button class="btn header-btn" aria-label="Ayuda">
                    <i class="bi bi-question-circle" style="font-size: 1.5rem; color: white;"></i>
                </button>
            }
        </div>
    </header>

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="app-footer">
        <div class="container-fluid d-flex flex-wrap align-items-center justify-content-between px-3 py-2">
            <div class="footer-peru">
                PERU
            </div>
            <div class="d-flex gap-3">
                <a href="#" class="footer-link">Política de Cookies</a>
                <a href="#" class="footer-link">Términos y Condiciones</a>
            </div>
        </div>
    </footer>

    <!-- Cookie Banner -->
    <div class="cookie-banner" id="cookieBanner">
        <div class="container-fluid d-flex flex-wrap align-items-center justify-content-between px-3 py-3 gap-2">
            <p class="cookie-text mb-0">
                Este sitio web utiliza cookies propias y de terceros para mejorar su experiencia de navegación y mostrarle publicidad personalizada.
                <a href="#" class="cookie-link">Más información</a>
            </p>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-light cookie-optout-btn" onclick="handleCookieOptOut()">Opt out</button>
                <button class="btn btn-sm btn-outline-light" onclick="closeCookieBanner()" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
        function closeCookieBanner() {
            document.getElementById('cookieBanner').style.display = 'none';
        }
        function handleCookieOptOut() {
            alert('Ha optado por no recibir cookies de terceros.');
            closeCookieBanner();
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>